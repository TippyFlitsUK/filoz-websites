---
interface Props {
  title?: string
  description?: string
}
const {
  title = 'DealBot — Filecoin storage deal analytics',
  description = 'Live performance metrics for automated Filecoin storage deals across Synapse storage providers.',
} = Astro.props
const isStaging = import.meta.env.PROD_BUILD !== '1'
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {isStaging && <meta name="robots" content="noindex, nofollow" />}
    <script is:inline src="/runtime-config.js"></script>
    <script is:inline>
      (function () {
        var cfg = window.__DEALBOT_CONFIG__ || {};
        var domain = cfg.PLAUSIBLE_DATA_DOMAIN;
        if (!domain) return;
        var s = document.createElement('script');
        s.defer = true;
        s.src = 'https://plausible.io/js/script.js';
        s.setAttribute('data-domain', domain);
        document.head.appendChild(s);
      })();
    </script>
  </head>
  <body>
    <div id="root">
      <slot />
    </div>
  </body>
</html>
